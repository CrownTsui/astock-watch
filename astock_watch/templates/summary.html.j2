<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>盯盘对比汇总 · {{ gen_date }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
{% if offline and assets.plotly_js %}<script>{{ assets.plotly_js | safe }}</script>
{% else %}<script src="{{ cdn.plotly_js }}"></script>{% endif %}
<style>
  *,*::before,*::after{ margin:0; padding:0; box-sizing:border-box; }
  :root{
    --bg:       #0D1117;
    --surface:  #161B22;
    --border:   #30363D;
    --gold:     #C9A96E;
    --gold-dim: #8B7348;
    --up:       {{ color.up }};
    --down:     {{ color.down }};
    --neutral:  {{ color.neutral }};
    --text:     #F0F6FC;
    --muted:    #8B949E;
  }
  body{
    background: var(--bg); color: var(--text);
    font-family: 'Noto Sans SC','DM Sans',sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  .wrap{ max-width:1140px; margin:0 auto; padding:20px 16px 40px; }

  .topbar{
    display:flex; justify-content:space-between; align-items:center;
    padding:12px 0; border-bottom:1px solid var(--border); margin-bottom:20px;
    font-size:.82rem; color:var(--muted);
  }
  .topbar .brand{ font-weight:600; color:var(--text); letter-spacing:.03em; }
  .topbar .brand span{ color:var(--gold); }

  .hero{
    padding:20px 0 16px; border-bottom:1px solid var(--gold-dim); margin-bottom:20px;
    display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:12px;
  }
  .hero .title{ font-size:1.4rem; font-weight:700; }
  .hero .sub{ font-size:.82rem; color:var(--muted); margin-top:4px; }

  .card{
    background:var(--surface); border:1px solid var(--border);
    border-radius:8px; padding:20px; margin-top:16px;
  }
  .card-title{
    font-size:.82rem; font-weight:600; color:var(--gold);
    text-transform:uppercase; letter-spacing:.08em; margin-bottom:16px;
    display:flex; align-items:center; gap:8px;
  }
  .card-title::after{ content:''; flex:1; height:1px; background:var(--border); }

  .chart-box{ min-height:440px; }

  /* ====== Rank Table ====== */
  .rank-wrap{ overflow-x:auto; }
  table.rank{
    width:100%; font-size:.85rem; border-collapse:collapse;
    font-family: 'Noto Sans SC','DM Sans',sans-serif;
  }
  table.rank th, table.rank td{
    padding:10px 8px; border-bottom:1px solid var(--border);
    text-align:center; white-space:nowrap;
  }
  table.rank th{
    background:var(--bg); color:var(--gold); font-weight:600;
    font-size:.76rem; text-transform:uppercase; letter-spacing:.05em;
    position:sticky; top:0;
  }
  table.rank tr:hover td{ background:rgba(201,169,110,.05); }
  table.rank td.name{ text-align:left; font-weight:600; }
  table.rank td.name .code{ color:var(--muted); font-weight:400; font-size:.76rem; }
  table.rank .mono{ font-family:'JetBrains Mono',monospace; }

  .pill{
    display:inline-block; padding:2px 10px; border-radius:4px;
    color:#fff; font-size:.78rem; font-weight:600;
  }
  .scoredot{
    display:inline-block; min-width:36px; padding:2px 6px; border-radius:4px;
    color:#fff; font-size:.78rem; font-family:'JetBrains Mono',monospace;
  }
  .detail-link{
    color:var(--gold); text-decoration:none; font-weight:600; font-size:.82rem;
  }
  .detail-link:hover{ text-decoration:underline; }

  .disclaimer{ font-size:.76rem; color:var(--muted); line-height:1.7; }

  .up{ color:var(--up); }
  .down{ color:var(--down); }
</style>
</head>
<body>
<div class="wrap">

  <div class="topbar">
    <div class="brand">astock-<span>watch</span> · 对比汇总</div>
    <div>{{ gen_time }}</div>
  </div>

  <div class="hero">
    <div>
      <div class="title">多股盯盘对比</div>
      <div class="sub">{{ items|length }} 支标的 · 报告日 {{ gen_date }} · 按综合评分降序</div>
    </div>
  </div>

  {% if has_mock %}
  <div style="background:#3D2E1C;border:1px solid #C9A96E;color:#C9A96E;border-radius:6px;padding:10px 16px;margin-top:12px;font-size:.84rem;font-weight:500;">
    ⚠️ 部分标的为模拟数据，相关结论仅供演示。
  </div>
  {% endif %}

  <div class="card">
    <div class="card-title">三维评分对比</div>
    <div id="comp-chart" class="chart-box"></div>
  </div>

  <div class="card">
    <div class="card-title">个股研判一览</div>
    <div class="rank-wrap">
    <table class="rank">
      <thead><tr>
        <th>#</th><th>名称 / 代码</th><th>收盘</th><th>涨跌</th>
        <th>综合</th><th>技术</th><th>资金</th><th>消息</th>
        <th>操作</th><th>走势</th><th>风险</th><th>详情</th>
      </tr></thead>
      <tbody>
      {% for it in items %}
        {% set comp = it.composite or 0 %}
        {% set pc = it.pct_chg or 0 %}
        <tr>
          <td style="color:var(--muted);">{{ loop.index }}</td>
          <td class="name">{{ it.name }}<br><span class="code">{{ it.code }}{% if it.is_mock %} · 模拟{% endif %}</span></td>
          <td class="mono">{{ it.close }}</td>
          <td class="mono {{ 'up' if pc>=0 else 'down' }}">{{ it.pct_chg|pct }}</td>
          {% for v in [it.composite, it.technical, it.capital, it.news] %}
          <td><span class="scoredot" style="background:{{ color.up if (v or 0)>=55 else (color.down if (v or 0)<45 else color.neutral) }};">{{ v }}</span></td>
          {% endfor %}
          <td><span class="pill" style="background:{{ color.up if comp>=55 else (color.down if comp<45 else color.neutral) }};">{{ it.action }}</span></td>
          <td>{{ it.lead }}</td>
          <td>{{ it.risk_level }}</td>
          <td><a class="detail-link" href="{{ it.report_file }}" target="_blank">查看 →</a></td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    </div>
  </div>

  <div class="card">
    <div class="disclaimer">
      <strong>免责声明：</strong>本汇总由 astock-watch 自动生成，所有评分与建议为量化模型机械计算结果，<strong>不构成投资建议</strong>。股市有风险，决策需谨慎，据此操作风险自负。生成时间：{{ gen_time }}。
    </div>
  </div>

</div>
<script>
  const CFG={responsive:true, displaylogo:false, modeBarButtonsToRemove:['lasso2d','select2d'],
    paper_bgcolor:'#161B22', plot_bgcolor:'#161B22',
    font:{color:'#8B949E', family:"'Noto Sans SC','DM Sans',sans-serif"},
    xaxis:{gridcolor:'#30363D', zerolinecolor:'#30363D'},
    yaxis:{gridcolor:'#30363D', zerolinecolor:'#30363D'}};
  try{
    const f={{ comp_chart | safe }};
    if(f){
      if(f.layout){
        f.layout.paper_bgcolor='#161B22'; f.layout.plot_bgcolor='#161B22';
        f.layout.font=f.layout.font||{}; f.layout.font.color='#8B949E';
        if(f.layout.xaxis){ f.layout.xaxis.gridcolor='#30363D'; f.layout.xaxis.zerolinecolor='#30363D'; }
        if(f.layout.yaxis){ f.layout.yaxis.gridcolor='#30363D'; f.layout.yaxis.zerolinecolor='#30363D'; }
      }
      Plotly.newPlot('comp-chart', f.data, f.layout, CFG);
    }
  }catch(e){ console.error(e); }
</script>
</body>
</html>
